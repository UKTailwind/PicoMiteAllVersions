# host/Makefile.wasm — delegator.
#
# The real WASM build lives at ports/host_wasm/Makefile. This file stays
# as a thin delegator so host/build_wasm.sh keeps working while the
# retirement of host/ completes.

PORT_MAKEFILE := $(abspath $(dir $(lastword $(MAKEFILE_LIST)))/../ports/host_wasm/Makefile)

.PHONY: all clean

all:
	$(MAKE) -f $(PORT_MAKEFILE) all

clean:
	$(MAKE) -f $(PORT_MAKEFILE) clean
