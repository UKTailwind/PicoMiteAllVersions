CLS RGB(BLACK)

DIM INTEGER x1%(3), y1%(3), x2%(3), y2%(3), x3%(3), y3%(3), c%(3), f%(3)
x1%(0) = 10: y1%(0) = 40: x2%(0) = 30: y2%(0) = 40: x3%(0) = 20: y3%(0) = 55
x1%(1) = 40: y1%(1) = 40: x2%(1) = 60: y2%(1) = 40: x3%(1) = 50: y3%(1) = 55
x1%(2) = 70: y1%(2) = 40: x2%(2) = 90: y2%(2) = 40: x3%(2) = 80: y3%(2) = 55
x1%(3) = -1: y1%(3) = -1: x2%(3) = -1: y2%(3) = -1: x3%(3) = -1: y3%(3) = -1
c%(0) = RGB(RED): f%(0) = RGB(RED)
c%(1) = RGB(GREEN): f%(1) = RGB(CYAN)
c%(2) = RGB(BLUE): f%(2) = RGB(YELLOW)

TRIANGLE x1%(), y1%(), x2%(), y2%(), x3%(), y3%(), c%(), f%()

PRINT "done"
END
