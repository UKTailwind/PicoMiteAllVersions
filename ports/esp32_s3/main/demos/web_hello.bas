10 CR$=CHR$(13)+CHR$(10)
20 DIM INTEGER OUT%(512/8)
30 LONGSTRING CLEAR OUT%()
40 LONGSTRING APPEND OUT%(),"HTTP/1.0 200 OK"+CR$
50 LONGSTRING APPEND OUT%(),"Content-Type: text/plain"+CR$
60 LONGSTRING APPEND OUT%(),"Connection: close"+CR$+CR$
70 LONGSTRING APPEND OUT%(),"hello from esp32 basic"
80 WEB CONNECT
90 DO
100 FOR C=1 TO MM.INFO(MAX CONNECTIONS)
110 IF MM.INFO(TCP REQUEST C) THEN WEB TCP SEND C,OUT%():WEB TCP CLOSE C
120 NEXT C
130 PAUSE 20
140 LOOP
